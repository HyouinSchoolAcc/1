    },
    {
      "content": "你敬佩武则天吗",
      "intimacy_delta": 0.01,
      "role": "林路",
      "timestamp": "14:27"
    },
    {
      "content": "武则天很牛啊",
      "intimacy_delta": 0.01,
      "role": "User",
      "timestamp": "14:27"
    },
    {
      "content": "大女人中的大女人",
