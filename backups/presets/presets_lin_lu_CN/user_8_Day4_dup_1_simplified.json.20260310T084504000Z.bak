  "character_schedule": {
    "afternoon": "批改部分作业，发现有学生抄袭，得联系谈话。在树下放松，看到小情侣手牵手亲嘴，觉得真青春，结果发现是自己的学生，尴尬跑了。",
    "day": 4,
    "evening": "上校内告白墙，发现有学生说自己很帅，暗爽。改专著第三章，补充地方志。",
    "morning": "备课《唐诗宋词鉴赏》找了3个版本的《漱玉词》对比，设计课堂朗读，自己模仿古人念诗，看视频。",
    "night": "",
    "noon": ""
  },
