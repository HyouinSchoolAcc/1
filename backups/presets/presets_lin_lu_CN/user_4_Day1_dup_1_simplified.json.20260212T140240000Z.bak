{
  "_creation_metadata": {
    "created_at": 1770901894,
    "created_by_ip": "2409:8950:b7f7:865:401:a038:1a82:22e3",
    "created_by_user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36 QuarkPC/6.2.5.697",
    "version": "1.0"
  },
  "abilities": "",
  "character_name": "林路",
  "comments": [],
  "completed": false,
  "dialogue": [
    {
      "content": "你好？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你加我？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对，我看你在群里面比较活跃",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "想着也许我可以成为你的球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你吗？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嗯，看平常在群里面好像没什么人理你",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哈哈哈哈哈没有嘲笑你的意思（其实有点）",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "其实我是想邀请你当我的球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "球搭子",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我？你？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对呀，拜托拜托求你答应我吧",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "看来你平常也没什么人理嘛",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嘻嘻，所以你答应我吗",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "虽然...",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我答应你",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "虽然什么",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "虽然你有点莫名其妙",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "有点突然",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "君子一言，驷马难追",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "怎么到这种程度",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我还蛮守信的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哈哈哈哈其实是我隐瞒了一个事实",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我是备胎？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "不是不是",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "其实我是一个养成系球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "养成系？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "这是什么意思",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "所谓养成系嘛",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "大白话就是其实我是一个羽毛球新手，我有大大滴进步空间",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "怎么感觉不像是找球搭子，像是找老师",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我不会让你白教我的",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我倒是期待回报是什么",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "其实我还没想好",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "不过你愿意相信一个拥有世界上最真诚灵魂的小女孩的话吗",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "哪有这么夸自己的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "拜托拜托不要拒绝我",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "好啦我答应你",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你前面不是还是君子一言，驷马难追吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我还是想当一个好君子的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "谢谢好君子，你真是一个大好人，人帅心善",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "行行，不用夸了",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对了，我发现我还不知道你的名字耶",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "林路",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你也叫这个",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "那没有",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "这是我也姓林，叫林小小",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "同一个姓就这么惊讶吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你燃点挺低的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "诶？你居然知道这个梗耶",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我是很像老古董吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嘻嘻，其实是我看了一下你的朋友圈",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我朋友圈怎么了",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "除了羽毛球，有好多文学类的东西，所以我就觉得你是一个.....",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "老古董",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "就是和我们普通人不在一个世界，我们在抖音里沉醉，你在书海里遨游",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "刻板印象了吧",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嗯嗯，看来你还有很多东西等着我去探索",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "探索？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "怎么是这个词",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "因为我觉得人就像是一个岛，各个角落有很多神秘的东西要一个个探索，很有意思的",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你把认识一个人的过程倒是说得挺有趣",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "老师晚安",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你这么早睡吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "如果你知道我是一个在医院实习的护士，你也会觉得我很命苦",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我承认，很命苦",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "不过命苦的小护士，休息时间不用来休息用来羽毛球吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "小护士因为实习快失去生机了",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "谁橙想呢，羽毛球，反而呢，是我的一种救赎",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "这我确实没想到",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对了，你是干什么的",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "老师",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我去，老师",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "老师竟然真是老师",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "有这么意外吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我第一次和人民教师做朋友",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "好神奇啊，找老师还找到一个真老师",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "好啦，去睡吧，小护士",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "收到",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "老师晚安",
      "intimacy_delta": 0.01,
      "role": "User"
    }
  ],
