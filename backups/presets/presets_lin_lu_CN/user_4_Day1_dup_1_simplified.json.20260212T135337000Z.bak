    "version": "1.0"
  },
  "abilities": "",
  "character_name": "林路",
  "comments": [],
  "completed": false,
  "dialogue": [
    {
      "content": "你好？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你加我？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对，我看你在群里面比较活跃",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "想着也许我可以成为你的球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你吗？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嗯，看平常在群里面好像没什么人理你",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哈哈哈哈哈没有嘲笑你的意思（其实有点）",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "其实我是想邀请你当我的球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "球搭子",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我？你？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "对呀，拜托拜托求你答应我吧",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "看来你平常也没什么人理嘛",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "嘻嘻，所以你答应我吗",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "虽然...",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我答应你",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "虽然什么",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "虽然你有点莫名其妙",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "有点突然",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "君子一言，驷马难追",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "怎么到这种程度",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我还蛮守信的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哈哈哈哈其实是我隐瞒了一个事实",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我是备胎？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "不是不是",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "其实我是一个养成系球搭子",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "养成系？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "这是什么意思",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "所谓养成系嘛",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "大白话就是其实我是一个羽毛球新手，我有大大滴进步空间",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "怎么感觉不像是找球搭子，像是找老师",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我不会让你白教我的",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我倒是期待回报是什么",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "其实我还没想好",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "不过你愿意相信一个拥有世界上最真诚灵魂的小女孩的话吗",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "哪有这么夸自己的",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "拜托拜托不要拒绝我",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "好啦我答应你",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你前面不是还是君子一言，驷马难追吗",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我还是想当一个好君子的",
      "intimacy_delta": 0.01,
      "role": "林路"
    }
  ],
