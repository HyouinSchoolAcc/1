    "created_by_user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36 QuarkPC/6.4.5.737",
    "version": "1.0"
  },
  "abilities": "",
  "category": "in_works",
  "character_name": "林路",
  "comments": [],
  "completed": false,
  "dialogue": [
    {
      "content": "那个，你好，请问您就是林路先生吗？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我是，请说。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "太好啦！我没有找错人！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "您好，我是zero，是林阿姨介绍过来的！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我找你是因为",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "啧。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "不好意思啊，我没有结婚的打算，我这辈子都不会结婚的。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "啊？哦哦，好的。",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我妈那边，我会说的，不好意思，耽误你了。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "啊？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "那个，林先生，您是不是误会了点什么啊？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我不是过来和你相亲的，我是过来请教你一些问题的！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "您误会我了！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "啊？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "咳咳，不好意思，最近母亲催的实在是有点紧。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我明明都说过了，我不想结婚。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "但是他们没有一个人把我的话放在心里。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哎呀，没事没事，这种事情，很正常的啦~",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "就像我的母上大人一样，一天到晚的不是催我出去找工作，就是催我结婚的。",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我明明都说啦，创作，就是我的事业！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "可是她一点也听不进去，说什么，你不出去上班，怎么找对象，怎么找婆家，真的是，一天到晚烦死了！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "看来大家的父母，都是一个样子啊。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "可能全天下的父母都是这样子吧，一个劲的把自己认为好的事情安置在自己的孩子身上，强迫他们去做自己不愿意做的事情。",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "就是网络上常说的，中国式家长！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "噗~",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你这么说的话，确实是有点像，封建，愚昧。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你找我是有什么事情吗？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "哦哦，是这个样子的，我最近在写一篇历史向的小说，虽然随随便便的写，逻辑也通畅，但是我想对我的作品负责，正好林阿姨说您在大学里面做历史系的教授，我就想请教一下。",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "会不会有点打扰您了呀，林先生？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "这不是打不打扰的问题。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我研究的是中国当代文学史，主讲《中国古代文学史（唐宋卷）》和选修课《唐诗宋词鉴赏》。",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "？？？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "？！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "等等，你是研究文学的？！",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "是的。",
      "intimacy_delta": 0.01,
      "role": "林路"
    }
  ],
