      "timestamp": "13:45",
      "timestampManuallyEdited": true
    },
    {
      "content": "下午好啊！",
      "intimacy_delta": 0.01,
      "role": "林路",
      "timestamp": "13:45"
    },
    {
      "content": "嗯，醒来之后发了会呆",
