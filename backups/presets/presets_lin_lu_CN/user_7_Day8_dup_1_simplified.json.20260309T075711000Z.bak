    },
    {
      "content": "[[sticker:uploads/upload_1772004899068193972.jpg]]",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "hhhh",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "什么意思？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "啊，我以为你看过这个表情，这个表情意思是我也要死吗?",
