      "role": "林路"
    },
    {
      "content": "好吧",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "你课上完了吗？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "嗯，今天的课已经上完了",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "你想聊，就聊个五毛的吧",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "聊一块的行不行？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": " 请打到我的收款码里",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "hhh捞男",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "我还没有要蜜雪冰城",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "等我要了蜜雪冰城再说我捞",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "hhhh真的假的？你不会真的让女人给你点蜜雪冰城吧？",
      "intimacy_delta": 0.01,
      "role": "User"
    },
    {
      "content": "啊？",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "我是在玩那个梗啊",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "男生说女生捞",
      "intimacy_delta": 0.01,
      "role": "林路"
    },
    {
      "content": "问捞他什么了",
      "intimacy_delta": 0.01,
