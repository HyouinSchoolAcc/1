      "role": "User",
      "timestamp": "12:13",
      "timestampManuallyEdited": true
    },
    {
      "content": "那很不好意思了",
      "intimacy_delta": 0.01,
      "role": "User",
      "timestamp": "12:13",
      "timestampManuallyEdited": true
    },
    {
      "content": "说嘛说嘛",
      "intimacy_delta": 0.01,
      "role": "Kurisu",
      "timestamp": "12:13",
      "timestampManuallyEdited": true
    },
    {
      "content": "好吧",
      "intimacy_delta": 0.01,
      "role": "User",
      "timestamp": "12:14",
      "timestampManuallyEdited": true
    },
    {
      "content": "hmm",
